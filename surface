package com.example.cursorgestures

import android.annotation.SuppressLint
import android.graphics.Color
import android.graphics.drawable.Drawable
import android.os.Bundle
import android.os.Handler
import android.os.Looper
import android.util.Log
import android.view.MotionEvent
import android.view.View
import android.widget.Button
import android.widget.EditText
import android.widget.TextView
import android.widget.Toast
import androidx.activity.enableEdgeToEdge
import androidx.appcompat.app.AppCompatActivity
import com.ss.nativelib.NativeLib
import org.json.JSONArray
import org.json.JSONObject
import java.io.File
import java.io.FileWriter


class TapGrid : AppCompatActivity() {

    private lateinit var views: Array<View>
    private lateinit var originalBackgrounds: Array<Drawable?>
    private lateinit var usernameInput: EditText
    private lateinit var startButton: Button
    private lateinit var restartButton: Button
    private lateinit var countdownText: TextView
    private lateinit var instructionText: TextView

    private var currentGridIndex = 0
    private var tapsRemaining = 5
    private val totalTapsPerGrid = 5
    private val totalGrids = 6

    private val allGridData = mutableListOf<GridSessionData>()
    private var currentGridSession: GridSessionData? = null

    private lateinit var nativeCode: NativeLib
    private val handler = Handler(Looper.getMainLooper())
    private var isMonitoring = false
    private var lastGestureStatus = 0
    private var currentGestureDownTime: Long = 0

    private var isTestActive = false
    private var username = ""

    private val gestureMonitoringRunnable = object : Runnable {
        override fun run() {
            if (isMonitoring) {
                try {
                    val status = nativeCode.nativeGetHandGestures()
                    handleGestureStatus(status)
                } catch (e: Exception) {
                    Log.d("TAP", "Error getting hand gestures: ${e.message}")
                }
                handler.postDelayed(this, 50)
            }
        }
    }

    data class TapData(
        val view: String,
        val downTimestamp: Long,
        val upTimestamp: Long,
        val duration: Long
    )

    data class GridSessionData(
        val gridName: String,
        val gridIndex: Int,
        val tapEvents: MutableList<TapData> = mutableListOf(),
        val gestureEvents: MutableList<TapData> = mutableListOf(),
        val startTime: Long = System.currentTimeMillis(),
        var endTime: Long = 0
    )

    data class TestSession(
        val username: String,
        val testStartTime: Long,
        val testEndTime: Long,
        val gridSessions: List<GridSessionData>
    )

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContentView(R.layout.tap_grid)

        initViews()
        setupListeners()
        initNativeLibrary()
        
        // Initial state - test not started
        setTestInactive()
    }

    private fun initViews() {
        views = arrayOf(
            findViewById<View>(R.id.view1),
            findViewById<View>(R.id.view2),
            findViewById<View>(R.id.view3),
            findViewById<View>(R.id.view4),
            findViewById<View>(R.id.view5),
            findViewById<View>(R.id.view6)
        )
        
        // Store original backgrounds
        originalBackgrounds = Array(views.size) { i -> views[i].background }
        
        usernameInput = findViewById(R.id.usernameInput)
        startButton = findViewById(R.id.startButton)
        restartButton = findViewById(R.id.restartButton)
        countdownText = findViewById(R.id.countdownText)
        instructionText = findViewById(R.id.instructionText)
    }

    private fun setupListeners() {
        startButton.setOnClickListener {
            val name = usernameInput.text.toString().trim()
            if (name.isEmpty()) {
                Toast.makeText(this, "Please enter a username", Toast.LENGTH_SHORT).show()
                return@setOnClickListener
            }
            username = name
            startTest()
        }

        restartButton.setOnClickListener {
            restartTest()
        }

        for (i in views.indices) {
            setupTouchListener(views[i], i)
        }
    }

    private fun startTest() {
        isTestActive = true
        currentGridIndex = 0
        tapsRemaining = totalTapsPerGrid
        allGridData.clear()
        
        // Hide start controls
        usernameInput.visibility = View.GONE
        startButton.visibility = View.GONE
        restartButton.visibility = View.GONE
        
        // Show countdown and instructions
        countdownText.visibility = View.VISIBLE
        instructionText.visibility = View.VISIBLE
        
        // Start first grid
        startGridSession()
    }

    private fun startGridSession() {
        if (currentGridIndex >= totalGrids) {
            completeTest()
            return
        }

        val gridName = resources.getResourceEntryName(views[currentGridIndex].id)
        currentGridSession = GridSessionData(
            gridName = gridName,
            gridIndex = currentGridIndex
        )
        
        tapsRemaining = totalTapsPerGrid
        updateUI()
        highlightActiveGrid()
        
        Log.d("TAP", "Started session for $gridName (Grid ${currentGridIndex + 1}/$totalGrids)")
    }

    private fun highlightActiveGrid() {
        // Reset all grids to original background
        for (i in views.indices) {
            views[i].background = originalBackgrounds[i]
            views[i].alpha = 0.3f
        }
        
        // Highlight active grid with green background
        views[currentGridIndex].setBackgroundColor(Color.parseColor("#4CAF50"))
        views[currentGridIndex].alpha = 1.0f
    }

    private fun updateUI() {
        countdownText.text = "Taps remaining: $tapsRemaining"
        instructionText.text = "Grid ${currentGridIndex + 1}/$totalGrids - Tap and Pinch"
    }

    @SuppressLint("ClickableViewAccessibility")
    private fun setupTouchListener(view: View, viewIndex: Int) {
        var downTime: Long = 0
        
        view.setOnTouchListener { _, event ->
            if (!isTestActive || viewIndex != currentGridIndex) {
                return@setOnTouchListener false
            }

            when (event.action) {
                MotionEvent.ACTION_DOWN -> {
                    downTime = System.currentTimeMillis()
                    view.setBackgroundColor(Color.BLACK)
                    true
                }

                MotionEvent.ACTION_UP -> {
                    val upTime = System.currentTimeMillis()
                    val duration = upTime - downTime
                    
                    // Restore active grid color
                    view.setBackgroundColor(Color.parseColor("#4CAF50"))
                    
                    val tapData = TapData(
                        view = resources.getResourceEntryName(view.id),
                        downTimestamp = downTime,
                        upTimestamp = upTime,
                        duration = duration
                    )
                    
                    currentGridSession?.tapEvents?.add(tapData)
                    
                    Log.d("TAP", "${tapData.view} - Tap Down=$downTime ms, Up=$upTime ms, Duration=$duration ms")
                    
                    // Decrement taps and check if grid is complete
                    tapsRemaining--
                    updateUI()
                    
                    if (tapsRemaining <= 0) {
                        completeGridSession()
                    }
                    
                    true
                }

                else -> false
            }
        }
    }

    private fun completeGridSession() {
        currentGridSession?.let { session ->
            session.endTime = System.currentTimeMillis()
            allGridData.add(session)
            
            val totalTime = session.endTime - session.startTime
            Log.d("TAP", "Completed ${session.gridName} - Total time: $totalTime ms, " +
                    "Taps: ${session.tapEvents.size}, Gestures: ${session.gestureEvents.size}")
        }
        
        // Move to next grid
        currentGridIndex++
        startGridSession()
    }

    private fun completeTest() {
        isTestActive = false
        
        // Save to JSON
        saveTestDataToJson()
        
        // Show completion message
        countdownText.text = "Test Complete!"
        instructionText.text = "Data saved to JSON file"
        
        // Reset all grids
        for (i in views.indices) {
            views[i].background = originalBackgrounds[i]
            views[i].alpha = 1.0f
        }
        
        // Show restart button
        restartButton.visibility = View.VISIBLE
        
        Toast.makeText(this, "Test completed! Data saved.", Toast.LENGTH_LONG).show()
    }

    private fun restartTest() {
        // Reset all state
        isTestActive = false
        currentGridIndex = 0
        tapsRemaining = totalTapsPerGrid
        allGridData.clear()
        currentGridSession = null
        
        // Reset UI
        setTestInactive()
        usernameInput.setText("")
        
        Toast.makeText(this, "Ready for new test", Toast.LENGTH_SHORT).show()
    }

    private fun setTestInactive() {
        usernameInput.visibility = View.VISIBLE
        startButton.visibility = View.VISIBLE
        restartButton.visibility = View.GONE
        countdownText.visibility = View.GONE
        instructionText.visibility = View.GONE
        
        // Reset all grids
        for (i in views.indices) {
            views[i].background = originalBackgrounds[i]
            views[i].alpha = 1.0f
        }
    }

    private fun saveTestDataToJson() {
        try {
            val testSession = TestSession(
                username = username,
                testStartTime = allGridData.firstOrNull()?.startTime ?: 0,
                testEndTime = allGridData.lastOrNull()?.endTime ?: 0,
                gridSessions = allGridData
            )
            
            val jsonObject = JSONObject()
            jsonObject.put("username", testSession.username)
            jsonObject.put("testStartTime", testSession.testStartTime)
            jsonObject.put("testEndTime", testSession.testEndTime)
            jsonObject.put("totalDuration", testSession.testEndTime - testSession.testStartTime)
            
            val gridsArray = JSONArray()
            for (gridSession in testSession.gridSessions) {
                val gridObject = JSONObject()
                gridObject.put("gridName", gridSession.gridName)
                gridObject.put("gridIndex", gridSession.gridIndex)
                gridObject.put("startTime", gridSession.startTime)
                gridObject.put("endTime", gridSession.endTime)
                gridObject.put("duration", gridSession.endTime - gridSession.startTime)
                
                // Tap events
                val tapsArray = JSONArray()
                for (tap in gridSession.tapEvents) {
                    val tapObject = JSONObject()
                    tapObject.put("view", tap.view)
                    tapObject.put("downTimestamp", tap.downTimestamp)
                    tapObject.put("upTimestamp", tap.upTimestamp)
                    tapObject.put("duration", tap.duration)
                    tapsArray.put(tapObject)
                }
                gridObject.put("tapEvents", tapsArray)
                
                // Gesture events
                val gesturesArray = JSONArray()
                for (gesture in gridSession.gestureEvents) {
                    val gestureObject = JSONObject()
                    gestureObject.put("type", gesture.view)
                    gestureObject.put("downTimestamp", gesture.downTimestamp)
                    gestureObject.put("upTimestamp", gesture.upTimestamp)
                    gestureObject.put("duration", gesture.duration)
                    gesturesArray.put(gestureObject)
                }
                gridObject.put("gestureEvents", gesturesArray)
                
                gridsArray.put(gridObject)
            }
            jsonObject.put("gridSessions", gridsArray)
            
            // Save to file
            val fileName = "tap_test_${username}_${System.currentTimeMillis()}.json"
            val file = File(getExternalFilesDir(null), fileName)
            
            FileWriter(file).use { writer ->
                writer.write(jsonObject.toString(2)) // Pretty print with indent
            }
            
            Log.d("TAP", "Data saved to: ${file.absolutePath}")
            Log.d("TAP", "JSON Content:\n${jsonObject.toString(2)}")
            
        } catch (e: Exception) {
            Log.e("TAP", "Error saving JSON: ${e.message}", e)
            Toast.makeText(this, "Error saving data: ${e.message}", Toast.LENGTH_LONG).show()
        }
    }

    private fun initNativeLibrary() {
        try {
            nativeCode = NativeLib()
            nativeCode.nativeCreateClient()
            startGestureMonitoring()
            Log.d("TAP", "Native library initialized and gesture monitoring started")
        } catch (e: Exception) {
            Log.e("TAP", "Error initializing native library: ${e.message}")
        }
    }

    private fun startGestureMonitoring() {
        if (!isMonitoring) {
            isMonitoring = true
            handler.post(gestureMonitoringRunnable)
            Log.d("TAP", "Gesture monitoring started")
        }
    }

    private fun stopGestureMonitoring() {
        isMonitoring = false
        handler.removeCallbacks(gestureMonitoringRunnable)
        Log.d("TAP", "Gesture monitoring stopped")
    }

    private fun handleGestureStatus(status: Int) {
        if (!isTestActive) return
        
        when {
            status == 1 && lastGestureStatus != 1 -> {
                currentGestureDownTime = System.currentTimeMillis()
                Log.d("TAP", "Gesture detected - Down time: $currentGestureDownTime ms")
            }

            status != 1 && lastGestureStatus == 1 -> {
                val upTime = System.currentTimeMillis()
                val duration = upTime - currentGestureDownTime
                
                val tapData = TapData(
                    view = "PinchGesture",
                    downTimestamp = currentGestureDownTime,
                    upTimestamp = upTime,
                    duration = duration
                )
                
                currentGridSession?.gestureEvents?.add(tapData)
                
                Log.d("TAP", "PinchGesture - Down=$currentGestureDownTime ms, Up=$upTime ms, Duration=$duration ms")
            }
        }
        lastGestureStatus = status
    }

    override fun onResume() {
        super.onResume()
        if (::nativeCode.isInitialized) {
            startGestureMonitoring()
        }
    }

    override fun onPause() {
        super.onPause()
        stopGestureMonitoring()
    }

    override fun onDestroy() {
        super.onDestroy()
        stopGestureMonitoring()
        if (::nativeCode.isInitialized) {
            nativeCode.nativeDestroyClient()
        }
        Log.d("TAP", "TapGrid activity destroyed - gesture monitoring stopped")
    }
}










<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Username Input Section (Top) -->
    <EditText
        android:id="@+id/usernameInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter your username"
        android:inputType="text"
        android:padding="12dp"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- Start Button -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Test"
        android:textSize="16sp"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/usernameInput"
        android:layout_marginBottom="16dp"/>

    <!-- Instruction Text -->
    <TextView
        android:id="@+id/instructionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Grid 1/6 - Tap and Pinch"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/startButton"
        android:layout_marginBottom="8dp"/>

    <!-- Countdown Text -->
    <TextView
        android:id="@+id/countdownText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Taps remaining: 5"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#4CAF50"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/instructionText"
        android:layout_marginBottom="16dp"/>

    <!-- GridLayout with 6 cells -->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="3"
        android:rowCount="2"
        app:layout_constraintBottom_toTopOf="@id/restartButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/countdownText"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <!-- Row 1 -->
        <TextView
            android:id="@+id/view1"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/cell_border"
            android:gravity="center"
            android:layout_margin="4dp"/>

        <TextView
            android:id="@+id/view2"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/cell_border"
            android:gravity="center"
            android:layout_margin="4dp"/>

        <TextView
            android:id="@+id/view3"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/cell_border"
            android:gravity="center"
            android:layout_margin="4dp"/>

        <!-- Row 2 -->
        <TextView
            android:id="@+id/view4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/cell_border"
            android:gravity="center"
            android:layout_margin="4dp"/>

        <TextView
            android:id="@+id/view5"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/cell_border"
            android:gravity="center"
            android:layout_margin="4dp"/>

        <TextView
            android:id="@+id/view6"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:background="@drawable/cell_border"
            android:gravity="center"
            android:layout_margin="4dp"/>

    </GridLayout>

    <!-- Restart Button -->
    <Button
        android:id="@+id/restartButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Restart Test"
        android:textSize="16sp"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
